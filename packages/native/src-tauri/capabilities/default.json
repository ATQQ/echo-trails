{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://192.168.31.173:1420/**",
          "all": true,
          "request": true
        },
        {
          "url": "http://**",
          "all": true,
          "request": true
        },
        {
          "url": "https://**",
          "all": true,
          "request": true
        },
        {
          "url": "ws://**",
          "all": true,
          "request": true
        },
        {
          "url": "wss://**",
          "all": true,
          "request": true
        }
      ]
    },
    "os:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "$APPDATA/databases/*"
        },
        {
          "path": "$APPCACHE/**"
        },
        {
          "path": "$APPLOCALDATA/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-lstat",
      "allow": [
        "$APPDATA/**",
        "$APPCACHE/**",
        "$APPLOCALDATA/**"
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        "$APPDATA/**",
        "$APPCACHE/**",
        "$APPLOCALDATA/**"
      ]
    },
    "fs:allow-app-write",
    "fs:allow-picture-write",
    "fs:allow-picture-read",
    "fs:write-all",
    "fs:allow-remove",
    "fs:allow-read-dir",
    "fs:allow-stat",
    "fs:allow-write",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        "$APPDATA/**",
        "$APPCACHE/**",
        "$APPLOCALDATA/**"
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        "$APPDATA/**",
        "$APPCACHE/**",
        "$APPLOCALDATA/**"
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPDATA",
        "$APPDATA/*",
        "$APPCACHE",
        "$APPCACHE/*",
        "$APPLOCALDATA",
        "$APPLOCALDATA/*"
      ]
    },
    "log:default",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load",
    "http:allow-fetch",
    "http:allow-fetch-cancel",
    "http:allow-fetch-cancel-body",
    "http:allow-fetch-read-body",
    "http:allow-fetch-send",
    "clipboard-manager:allow-write-text",
    "opener:default",
    "opener:allow-open-path"
  ]
}